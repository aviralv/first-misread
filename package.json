{
  "name": "first-misread",
  "version": "1.2.0",
  "description": "Stress-test your writing with synthetic reader personas. Find the first place your draft gets misunderstood.",
  "type": "module",
  "bin": {
    "first-misread": "src/cli/cli.js"
  },
  "keywords": [
    "writing",
    "editing",
    "feedback",
    "ai",
    "llm",
    "personas",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aviralv/first-misread.git"
  },
  "homepage": "https://github.com/aviralv/first-misread",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "src/core/format-detector.js",
    "src/core/llm-client.js",
    "src/core/pipeline.js",
    "src/core/analyzer.js",
    "src/core/selector.js",
    "src/core/simulator.js",
    "src/core/aggregator.js",
    "src/core/strengths.js",
    "src/cli/",
    "personas/"
  ],
  "scripts": {
    "prebuild": "node scripts/convert-personas.js",
    "predev": "node scripts/convert-personas.js",
    "build": "node esbuild.config.mjs production",
    "dev": "node esbuild.config.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "esbuild": "^0.25.0",
    "obsidian": "latest",
    "preact": "^10.25.0",
    "tslib": "^2.4.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  }
}
